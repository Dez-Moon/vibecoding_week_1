{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Management MVP schema",
  "description": "Logical schema for the SQLite database. SQL table names are plural; SQLAlchemy class names are singular. Maps 1:1 to backend/app/models.py.",
  "type": "object",
  "tables": {
    "users": {
      "model": "User",
      "fields": {
        "id": { "type": "string", "format": "uuid", "primary_key": true },
        "username": { "type": "string", "unique": true, "required": true },
        "created_at": { "type": "string", "format": "date-time", "required": true }
      }
    },
    "boards": {
      "model": "Board",
      "fields": {
        "id": { "type": "string", "format": "uuid", "primary_key": true },
        "user_id": {
          "type": "string",
          "format": "uuid",
          "foreign_key": "users.id",
          "unique": true,
          "required": true
        },
        "title": { "type": "string", "required": true },
        "created_at": { "type": "string", "format": "date-time", "required": true }
      },
      "constraints": [
        "UNIQUE (user_id) — one board per user for the MVP"
      ]
    },
    "columns": {
      "model": "Column",
      "fields": {
        "id": { "type": "string", "format": "uuid", "primary_key": true },
        "board_id": {
          "type": "string",
          "format": "uuid",
          "foreign_key": "boards.id",
          "required": true,
          "index": true
        },
        "title": { "type": "string", "required": true },
        "position": { "type": "integer", "required": true, "minimum": 0 },
        "created_at": { "type": "string", "format": "date-time", "required": true }
      },
      "constraints": [
        "UNIQUE (board_id, position) — no two columns in the same board share a slot"
      ]
    },
    "cards": {
      "model": "Card",
      "fields": {
        "id": { "type": "string", "format": "uuid", "primary_key": true },
        "column_id": {
          "type": "string",
          "format": "uuid",
          "foreign_key": "columns.id",
          "required": true,
          "index": true
        },
        "title": { "type": "string", "required": true },
        "details": { "type": "string", "default": "" },
        "position": { "type": "integer", "required": true, "minimum": 0 },
        "created_at": { "type": "string", "format": "date-time", "required": true },
        "updated_at": { "type": "string", "format": "date-time", "required": true }
      },
      "constraints": [
        "UNIQUE (column_id, position) — no two cards in the same column share a slot"
      ]
    }
  },
  "relationships": [
    { "from": "boards.user_id", "to": "users.id", "cardinality": "many-to-one" },
    { "from": "columns.board_id", "to": "boards.id", "cardinality": "many-to-one" },
    { "from": "cards.column_id", "to": "columns.id", "cardinality": "many-to-one" }
  ]
}
